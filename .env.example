# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — never expose to client
# Found in: Supabase project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database direct connection (for migrations)
# Found in: Supabase project → Settings → Database → Direct connection
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── App ─────────────────────────────────────────────────────────────────────
# Full URL of the app (no trailing slash)
# Local: http://localhost:3000 | Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Authentication ────────────────────────────────────────────────────────────
# Secret for hashing (generate with: openssl rand -base64 32)
AUTH_SECRET=your-random-secret-here

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_your-resend-key-here
RESEND_FROM_EMAIL=hello@yourdomain.com

# ─── Web Push (PWA notifications) ─────────────────────────────────────────────
# Generate VAPID keys (example): npx web-push generate-vapid-keys
# Public key is exposed to browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
# Private/public keys used by Supabase Edge Function `send-morning-push`
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_EMAIL=mailto:support@somnia.app
VAPID_SUBJECT=mailto:hello@yourdomain.com
CRON_SECRET=replace-with-a-random-secret

#─── Sentry ───────────────────────────────────────────────────────────────────
# Found in: sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=somnia
# Found in: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ─── Analytics ────────────────────────────────────────────────────────────────
# Found in: vercel.com → Project → Analytics (auto-injected on Vercel)
# Leave empty for local dev
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "true" to enable AI insights feature (requires additional API key)
NEXT_PUBLIC_FEATURE_AI_INSIGHTS=false
